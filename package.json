{
  "name": "competitor-promo-crawler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Daily competitor promotion crawler for Brazil betting/iGaming monitoring.",
  "scripts": {
    "login": "node src/login.mjs",
    "crawl": "node src/crawl.mjs",
    "crawl:public": "node src/crawl-public.mjs",
    "crawl:browser": "node src/crawl-browser-live.mjs",
    "crawl:today": "node src/crawl.mjs --date=today",
